<!DOCTYPE html>
<html>
<head>
    <title>Todo Dashboard</title>
</head>
<body>

<h1>My Tasks</h1>

<hr>

<h3>Create Task</h3>

<form action="/tasks" method="POST">

    <input
        type="text"
        name="title"
        placeholder="Task title"
        required
    />

    <br><br>

    <input
        type="date"
        name="dueDate"
        required
    />

    <br><br>

    <button type="submit">
        Add Task
    </button>

</form>

<hr>

<h2>Task List</h2>

<% if(tasks.length === 0){ %>

<p>No tasks yet.</p>

<% } %>

<ul>

<% tasks.forEach(task => { %>

<li>

<strong><%= task.title %></strong>

<br>

Status:
<%= task.status %>

<br>

Due Date:
<%= new Date(task.dueDate).toLocaleDateString() %>

<br>

Overdue:

<% if(task.overdue){ %>

<span style="color:red;">
YES
</span>

<% }else{ %>

<span style="color:green;">
NO
</span>

<% } %>

<br><br>

<% if(task.status !== "completed"){ %>

<form
action="/tasks/<%= task._id %>"
method="POST">

<input
type="hidden"
name="status"
value="completed"
/>

<button>
Mark Completed
</button>

</form>

<% }else{ %>

<strong>
Completed ✔
</strong>

<% } %>

<hr>

</li>

<% }) %>

</ul>

</body>
</html>